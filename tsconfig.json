{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "inlineSourceMap": false,
    "removeComments": false,
    "lib": ["DOM", "ES2023"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "builds"]
}
